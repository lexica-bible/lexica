#!/bin/sh
# Lexica pre-commit hook — the local twin of .github/workflows/ci.yml.
# Runs automatically on every `git commit`. Two jobs:
#   1. If you staged a frontend source file (static/src/*.jsx) but forgot to
#      rebuild, it rebuilds static/app.js for you and stages it.
#   2. Runs the invariant tests; if they fail, the commit is blocked.
#
# Installed via:  git config core.hooksPath scripts/githooks
# Skip it for one commit with:  git commit --no-verify

set -e

# --- 1. frontend: rebuild app.js if any source .jsx (or the builder) is staged
staged_src=$(git diff --cached --name-only | grep -E '^static/src/.*\.jsx$|^scripts/build-frontend\.js$' || true)
if [ -n "$staged_src" ]; then
  echo "pre-commit: frontend source changed — rebuilding app.js..."
  npm run build --silent
  if ! git diff --quiet -- static/app.js; then
    echo "pre-commit: app.js was stale — rebuilt and staged it for you."
    git add static/app.js
  fi
fi

# --- 2. tests: block the commit if an invariant breaks
echo "pre-commit: running invariant tests..."
python tests/test_strongs_join.py >/dev/null
python tests/test_build_invariants.py >/dev/null
python tests/test_folded_fixes.py >/dev/null
python tests/test_argmap.py >/dev/null
python tests/test_versification.py >/dev/null
python tests/test_corpus_panel.py >/dev/null
python tests/test_synthesis_no_leak.py >/dev/null
python tests/test_typed_strongs.py >/dev/null
python tests/test_render_head_no_phantom.py >/dev/null
python tests/test_lexica_agreement_parse.py >/dev/null
python tests/test_lexica_glossset_fold.py >/dev/null
python tests/test_lexica_detectors.py >/dev/null
python tests/test_draw_hints.py >/dev/null
python tests/test_lexica_section_split.py >/dev/null
python tests/test_section_matcher_sweep.py >/dev/null
python tests/test_ref_tail_expansion.py >/dev/null
python tests/test_coverage_gate.py >/dev/null
python tests/test_repair_pass.py >/dev/null
python tests/test_v11_probes.py >/dev/null
python tests/test_fix_lexica_raw.py >/dev/null
python tests/test_offline_gate_lints.py >/dev/null
python tests/test_quote_repair.py >/dev/null
python tests/test_draw_history.py >/dev/null
python tests/test_helper_double_tag.py >/dev/null
python tests/test_context_feed.py >/dev/null
node tests/test_ac_word_groups.js >/dev/null
node tests/test_rstack_logic.js >/dev/null
node tests/test_chrono_reconcile.js >/dev/null
node tests/test_library_order.js >/dev/null
node tests/test_render_markup.js >/dev/null
node tests/smoke_app.js >/dev/null
echo "pre-commit: all checks passed."
